{
  "schema": "https://wa3.dev/schemas/portable-skill-bundle-v0.json",
  "name": "wa3-spec",
  "display_name": "WA3 Spec",
  "version": "0.3.0-draft",
  "description": "Portable WA3 skill-contract specification bundle for agents and runtimes that need to read, validate, compile, render, or evolve .tdy contracts.",
  "license": "see-repository",
  "entrypoints": {
    "root_skill": "SKILL.md",
    "general": "AGENTS.md",
    "package": "docs/PACKAGE.md",
    "install_agents": "docs/INSTALL_AGENTS.md",
    "extract_contract": "docs/EXTRACT_CONTRACT.md",
    "publish_checklist": "docs/PUBLISH_CHECKLIST.md",
    "import_tofu": "docs/IMPORT_TOFU.md",
    "render_pipeline": "docs/RENDER_PIPELINE.md",
    "overview": "README.md",
    "example": "board.tdy",
    "builder_schema": "builder/answers.schema.json",
    "builder_template_catalog": "builder/templates/catalog.json",
    "builder_example": "builder/examples/board.answers.json",
    "product_showcase_example": "builder/examples/product_showcase.answers.json",
    "mobile_product_app_example": "builder/examples/mobile_product_app.answers.json",
    "design_templates": "design_templates",
    "design_template_catalog": "design_templates/catalog.json",
    "conformance": "conformance/README.md"
  },
  "adapters": {
    "codex": "skills/wa3-spec/SKILL.md",
    "haler": "adapters/haler/haler.skill.json",
    "claude_code": "adapters/claude-code/CLAUDE.md",
    "openhands": "adapters/openhands/README.md",
    "langgraph": "adapters/langgraph/README.md",
    "voiceflow": "adapters/voiceflow/README.md",
    "mistral": "adapters/mistral/README.md",
    "eigent": "adapters/eigent/README.md",
    "openclaw": "adapters/openclaw/OPENCLAW.md",
    "hermes": "adapters/hermes/HERMES.md",
    "claude_code_plugin": ".claude-plugin/plugin.json",
    "claude_code_marketplace": ".claude-plugin/marketplace.json"
  },
  "capabilities": [
    "review_wa3_contract",
    "author_wa3_contract",
    "build_wa3_from_answers",
    "extract_interface_contract",
    "extract_design_template",
    "bind_design_and_render",
    "lint_structure",
    "canonicalize",
    "verify_signature",
    "compile_interface_plan",
    "review_runtime_safety",
    "evolve_spec_compatibly"
  ],
  "required_invariants": [
    "core_enforces_security",
    "renderer_is_untrusted",
    "ed25519_canonical_signature_before_use",
    "namespace_classification_before_rejection",
    "unknown_extension_fields_preserved_for_canonical",
    "authoring_llm_is_untrusted",
    "builder_gates_before_file_write",
    "ai_output_never_operates_without_user_confirmation"
  ],
  "paths": {
    "builder": "builder",
    "builder_templates": "builder/templates",
    "builder_template_catalog": "builder/templates/catalog.json",
    "design_templates": "design_templates",
    "design_template_catalog": "design_templates/catalog.json",
    "vectors": "conformance/vectors",
    "archive": "archive",
    "codex_root_skill": "SKILL.md",
    "codex_skill": "skills/wa3-spec",
    "openhands_plugin": ".plugin/plugin.json",
    "openhands_setup": ".openhands/setup.sh",
    "openhands_hooks": ".openhands/hooks.json",
    "claude_plugin": ".claude-plugin/plugin.json"
  }
}
